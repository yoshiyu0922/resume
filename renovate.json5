{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": ["* 0-12 * * *"],
  "ignoreDeps": [],
  "labels": ["renovate"],
  "packageRules": [
    {
      "matchUpdateTypes": [
        'minor',
        'patch',
        'pin',
        'digest',
      ],
      automerge: true
    }
  ],
  "timezone": "Asia/Tokyo",
  "reviewers": [
    "yoshiyu0922"
  ]
}
